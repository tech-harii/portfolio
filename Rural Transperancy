### Step 4: Build Component A -- Patient Flow Predictor (Week 3-5)

```python
from sklearn.ensemble import RandomForestRegressor
from xgboost import XGBRegressor
from sklearn.model_selection import TimeSeriesSplit
from sklearn.metrics import mean_absolute_error
import pandas as pd
import numpy as np

def create_features(df):
    """Engineer features from raw appointment data."""
    daily = df.groupby('date').agg(
        patient_count=('patient_id', 'count'),
        no_shows=('status', lambda x: (x == 'no_show').sum()),
        walk_ins=('lead_days', lambda x: (x == 0).sum()),
        avg_duration=('duration_minutes', 'mean')
    ).reset_index()

    daily['day_of_week'] = pd.to_datetime(daily['date']).dt.dayofweek
    daily['month'] = pd.to_datetime(daily['date']).dt.month
    daily['day_of_month'] = pd.to_datetime(daily['date']).dt.day
    daily['week_of_year'] = pd.to_datetime(daily['date']).dt.isocalendar().week.astype(int)

    # Lag features
    for lag in [1, 2, 3, 5, 7]:
        daily[f'count_lag_{lag}'] = daily['patient_count'].shift(lag)

    # Rolling averages
    for window in [7, 14, 30]:
        daily[f'count_rolling_{window}'] = (
            daily['patient_count'].rolling(window).mean()
        )

    return daily.dropna()

def train_and_evaluate(daily_features):
    """Train ensemble model with time-series cross-validation."""
    feature_cols = [c for c in daily_features.columns
                    if c not in ['date', 'patient_count']]
    X = daily_features[feature_cols]
    y = daily_features['patient_count']

    tscv = TimeSeriesSplit(n_splits=5)

    rf_model = RandomForestRegressor(n_estimators=100, random_state=42)
    xgb_model = XGBRegressor(n_estimators=100, random_state=42)

    rf_errors, xgb_errors = [], []

    for train_idx, test_idx in tscv.split(X):
        X_train, X_test = X.iloc[train_idx], X.iloc[test_idx]
        y_train, y_test = y.iloc[train_idx], y.iloc[test_idx]

        rf_model.fit(X_train, y_train)
        xgb_model.fit(X_train, y_train)

        rf_errors.append(mean_absolute_error(y_test, rf_model.predict(X_test)))
        xgb_errors.append(mean_absolute_error(y_test, xgb_model.predict(X_test)))

    print(f"Random Forest MAE: {np.mean(rf_errors):.2f} (+/- {np.std(rf_errors):.2f})")
    print(f"XGBoost MAE: {np.mean(xgb_errors):.2f} (+/- {np.std(xgb_errors):.2f})")

    return rf_model, xgb_model
```

