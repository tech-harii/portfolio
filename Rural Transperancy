# DATASET 1: Kaggle Medical No-Show Appointments
# ─────────────────────────────────────────────────────────

def load_kaggle_noshow(filepath="data/KaggleV2-May-2016.csv"):
    """
    Load and preprocess the Kaggle no-show dataset.
    Download from: https://www.kaggle.com/datasets/joniarroba/noshowappointments
    Place the CSV in the data/ folder.
    """
    df = pd.read_csv(filepath)

    # Standardize column names
    df.columns = df.columns.str.strip().str.lower().str.replace('-', '_')

    # Parse dates
    df['scheduled_date'] = pd.to_datetime(df['scheduledday']).dt.date
    df['appointment_date'] = pd.to_datetime(df['appointmentday']).dt.date

    # Calculate lead time (key predictor for no-shows)
    df['lead_days'] = (
        pd.to_datetime(df['appointment_date']) -
        pd.to_datetime(df['scheduled_date'])
    ).dt.days

    # Binary target: 1 = no-show, 0 = showed up
    df['is_noshow'] = (df['no_show'] == 'Yes').astype(int)

    # Time-based features
    df['day_of_week'] = pd.to_datetime(df['appointment_date']).dt.dayofweek
    df['month'] = pd.to_datetime(df['appointment_date']).dt.month
    df['is_monday'] = (df['day_of_week'] == 0).astype(int)

    # Select features for ML
    feature_cols = [
        'age', 'gender', 'scholarship', 'hypertension', 'diabetes',
        'alcoholism', 'handicap', 'sms_received', 'lead_days',
        'day_of_week', 'month', 'is_monday'
    ]

    # Encode gender
    df['gender'] = (df['gender'] == 'F').astype(int)

    print(f"Loaded {len(df)} appointments")
    print(f"No-show rate: {df['is_noshow'].mean():.1%}")
    print(f"Date range: {df['appointment_date'].min()} to {df['appointment_date'].max()}")

    return df, feature_cols


