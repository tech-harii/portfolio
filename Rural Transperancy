```sql
-- Core tables for AWOS

CREATE TABLE appointments (
    id INTEGER PRIMARY KEY,
    patient_id TEXT,
    scheduled_date DATE,
    scheduled_time TIME,
    visit_type TEXT,           -- 'checkup', 'followup', 'urgent', 'procedure'
