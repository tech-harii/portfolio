);

CREATE TABLE staff_schedule (
    id INTEGER PRIMARY KEY,
    staff_id TEXT,
    date DATE,
    shift_start TIME,
    shift_end TIME,
    role TEXT                  -- 'physician', 'nurse', 'admin', 'tech'
);

CREATE TABLE resources (
    id INTEGER PRIMARY KEY,
    resource_type TEXT,        -- 'room', 'equipment'
    resource_name TEXT,
    available_from TIME,
    available_until TIME,
    status TEXT                -- 'available', 'in_use', 'maintenance'
);
